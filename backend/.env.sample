# ── TMDB ──
TMDB_API_KEY=select_your_tmdb_api_key_here

# ── Spoonacular ──
SPOONACULAR_API_KEY=select_your_spoonacular_api_key_here

# ── Google Books ──
GOOGLE_BOOKS_API_KEY=select_your_google_books_api_key_here

# ── OpenWeatherMap ──
