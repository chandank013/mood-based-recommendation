# ── Database ──
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=paste_your_password_here
DB_NAME=mood_recommender

# ── Groq API ──
GROQ_API_KEY=paste_your_groq_api_key_here
